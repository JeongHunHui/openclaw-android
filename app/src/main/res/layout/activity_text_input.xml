<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="#13131F"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="✏️ 메시지 입력"
        android:textColor="#C084FC"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp" />

    <EditText
        android:id="@+id/etMessage"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/input_bg"
        android:hint="슬랙으로 보낼 메시지..."
        android:inputType="textMultiLine"
        android:minLines="3"
        android:maxLines="6"
        android:padding="14dp"
        android:textColor="#E2E8F0"
        android:textColorHint="#475569"
        android:textSize="15sp"
        android:layout_marginBottom="16dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="end">

        <Button
            android:id="@+id/btnCancel"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:background="@drawable/btn_secondary_bg"
            android:text="취소"
            android:textColor="#94A3B8"
            android:layout_marginEnd="8dp" />

        <Button
            android:id="@+id/btnSend"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:background="@drawable/btn_primary_bg"
            android:text="전송 🚀"
            android:textColor="#FFFFFF" />

    </LinearLayout>
</LinearLayout>
