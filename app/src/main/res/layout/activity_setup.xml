<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D0D1A">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="28dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="32dp"
            android:text="🔮"
            android:textSize="56sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="8dp"
            android:text="훈희봇"
            android:textColor="#C084FC"
            android:textSize="30sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="40dp"
            android:text="처음이라 설정이 필요해 👀"
            android:textColor="#64748B"
            android:textSize="14sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Slack Bot Token (필수)"
            android:textColor="#94A3B8"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_marginBottom="6dp" />

        <EditText
            android:id="@+id/etBotToken"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/input_bg"
            android:hint="xoxb-..."
            android:inputType="textPassword"
            android:padding="14dp"
            android:textColor="#E2E8F0"
            android:textColorHint="#475569"
            android:textSize="14sp"
            android:layout_marginBottom="20dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Slack User Token (선택 — 내 이름으로 전송)"
            android:textColor="#94A3B8"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_marginBottom="6dp" />

        <EditText
            android:id="@+id/etUserToken"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/input_bg"
            android:hint="xoxp-... (없으면 비워둬)"
            android:inputType="textPassword"
            android:padding="14dp"
            android:textColor="#E2E8F0"
            android:textColorHint="#475569"
            android:textSize="14sp"
            android:layout_marginBottom="20dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Slack Channel ID"
            android:textColor="#94A3B8"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_marginBottom="6dp" />

        <EditText
            android:id="@+id/etChannel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/input_bg"
            android:hint="C0XXXXXXXXX"
            android:inputType="text"
            android:padding="14dp"
            android:textColor="#E2E8F0"
            android:textColorHint="#475569"
            android:textSize="14sp"
            android:layout_marginBottom="32dp" />

        <Button
            android:id="@+id/btnNext"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:background="@drawable/btn_primary_bg"
            android:text="저장하고 시작하기 🚀"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="12dp" />

    </LinearLayout>
</ScrollView>
